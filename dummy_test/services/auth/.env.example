# Copy to .env in this directory and replace every YOUR_* / bracketed value. Do not commit .env.

# Project Settings → API — Project URL (anon / public API only; not service_role).
# Hosted: https://<project-ref>.supabase.co  |  Local `supabase start`: http://127.0.0.1:54321
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Project Settings → API — anon (public) key
SUPABASE_KEY=YOUR_ANON_PUBLIC_KEY

# Project Settings → Database — Connection string (URI). Direct Postgres; not the anon JWT.
# Used by the auth Docker image on startup (migrations + seed). Omit only if you apply SQL yourself.
# Hosted (pooler, typical): paste the URI from the dashboard and keep ?sslmode=require if shown.
# Local Supabase CLI default: postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=postgresql://postgres:YOUR_DATABASE_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
