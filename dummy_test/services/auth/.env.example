# Copy this file to .env in this directory and set real values.
# Do not commit .env (see .gitignore).
#
# Hosted project: Project Settings → API (Project URL + anon public key; not service_role).
#
# Local Supabase CLI: from dummy_test run `supabase start`, then use the "API URL" and "anon key"
# printed in the terminal (defaults look like http://127.0.0.1:54321 and a JWT anon key).
# Apply migrations after changing SQL: `supabase db reset` (Docker must be running).

# Project URL (hosted https://…supabase.co or local http://127.0.0.1:54321)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# anon public key (not service_role)
SUPABASE_KEY=YOUR_ANON_PUBLIC_KEY
