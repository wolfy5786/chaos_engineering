# Security & Chaos Engineering Framework — environment defaults.
# Copy to .env at the repository root and set values. Do not commit .env.
#
# Usage:
#   cp .env.example .env            (Linux / macOS)
#   Copy-Item .env.example .env     (Windows PowerShell)

# ---------------------------------------------------------------------------
# Framework execution backend
# ---------------------------------------------------------------------------
# kubectl  — real cluster; requires kubectl + kubeconfig (default)
# null     — no-op backend for unit tests and dry runs (no cluster needed)
CHAOS_BACKEND=kubectl

# ---------------------------------------------------------------------------
# Workload generator (scenarios with a workload block)
# ---------------------------------------------------------------------------
# Used when a scenario's workload.targets.base_url is omitted or empty.
# Typical dummy_test URL with port-forward or Compose: http://localhost:8000
# WORKLOAD_BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Results output
# ---------------------------------------------------------------------------
# Directory where HTML and JSON reports are written after each pipeline run.
# Created automatically if it does not exist.
# RESULTS_DIR=results

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Override the default log level (INFO). Choices: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO
